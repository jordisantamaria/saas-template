{
  "name": "saas-template",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev dev:stripe",
    "lint": "turbo lint",
    "test": "turbo test",
    "test:e2e": "turbo test:e2e",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:generate": "pnpm --filter db generate",
    "db:migrate": "pnpm --filter db migrate",
    "db:studio": "pnpm --filter db studio",
    "db:seed": "pnpm --filter db seed",
    "analyze": "ANALYZE=true pnpm --filter web build"
  },
  "devDependencies": {
    "@nyxidiom/config": "workspace:*",
    "prettier": "^3.4.0",
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  }
}
