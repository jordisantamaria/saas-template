# ===========================================
# App
# ===========================================
# Optional: falls back to VERCEL_URL in deployments, localhost in dev
# NEXT_PUBLIC_APP_URL=https://tu-dominio.com

# ===========================================
# Database (Neon)
# ===========================================
DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/dbname?sslmode=require

# ===========================================
# Auth (Auth.js v5)
# ===========================================
# Generate with: npx auth secret
AUTH_SECRET=
# Production only: set to your deployed URL (next-auth auto-detects localhost in dev)
# AUTH_URL=https://tu-dominio.com
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY=re_xxx
EMAIL_FROM=onboarding@resend.dev

# ===========================================
# Payments (Stripe)
# ===========================================
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ===========================================
# Rate Limiting (Upstash Redis)
# ===========================================
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx

# ===========================================
# Error Tracking (Sentry)
# ===========================================
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# SENTRY_ORG, SENTRY_PROJECT, SENTRY_AUTH_TOKEN → solo en produccion (Vercel env vars)

# ===========================================
# Analytics (PostHog)
# ===========================================
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
# EU Cloud: https://eu.i.posthog.com | US Cloud: https://us.i.posthog.com
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ===========================================
# File Storage (Cloudflare R2)
# ===========================================
R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxx.r2.dev
